{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "lib": ["DOM", "ESNext"],
    "noEmit": true,
    "strict": true,
    "types": ["chrome", "node", "zotero-types"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "paths": {
      "@lib/*": ["./src/lib/*"],
      "@services": ["./src/services/index.ts"],
      "@services/*": ["./src/services/*"],
      "@ui": ["./src/ui/index.ts"],
      "@ui/*": ["./src/ui/*"]
    }
  },
  "include": [
    "src/env.d.ts",
    "src/app/**/*",
    "src/build/**/*",
    "src/lib/**/*",
    "src/services/**/*",
    "src/ui/**/*",
    "src/zotero/**/*"
  ],
  "exclude": ["node_modules", "dist"]
}
