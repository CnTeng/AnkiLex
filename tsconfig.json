{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "lib": ["DOM", "ESNext"],
    "noEmit": true,
    "strict": true,
    "types": ["chrome", "node", "zotero-types"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "paths": {
      "@lib/*": ["./src/lib/*"]
    }
  },
  "include": [
    "src/env.d.ts",
    "src/app/**/*",
    "src/lib/**/*",
    "src/zotero/**/*",
    "src/manifests/**/*"
  ],
  "exclude": ["node_modules", "dist"]
}
