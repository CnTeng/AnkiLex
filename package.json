{
  "name": "ankilex",
  "version": "0.0.1",
  "description": "Look up words in online dictionaries and add to Anki",
  "author": "CnTeng",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "test": "vitest run",
    "format": "prettier --write .",
    "clean": "rm -rf dist",
    "build:chrome": "tsx scripts/build.ts chrome",
    "build:firefox": "tsx scripts/build.ts firefox",
    "build:zotero": "tsx scripts/build.ts zotero",
    "build": "run-p -sl build:*",
    "package:chrome": "tsx scripts/build.ts chrome --package",
    "package:firefox": "tsx scripts/build.ts firefox --package",
    "package:zotero": "tsx scripts/build.ts zotero --package",
    "package": "npm run clean && run-p -sl package:*"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.0",
    "@types/chrome": "^0.1.36",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^25.3.5",
    "@vitest/browser": "^4.0.18",
    "adm-zip": "^0.5.16",
    "jsdom": "^27.4.0",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.0",
    "tsx": "^4.19.3",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-static-copy": "^3.2.0",
    "vitest": "^4.0.18",
    "zotero-types": "^4.1.2"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.7.6",
    "lucide": "^0.577.0",
    "tailwind-merge": "^3.4.1",
    "tailwind-variants": "^3.2.2"
  },
  "prettier": {
    "printWidth": 100,
    "plugins": [
      "prettier-plugin-tailwindcss"
    ],
    "tailwindFunctions": [
      "tv",
      "cn",
      "cx"
    ]
  }
}
